# Normalize all text files to LF line endings on commit. Working-tree
# checkout follows core.autocrlf / core.eol per platform but git stores LF.
# Without this, Windows clones with the default core.autocrlf=true produce
# CRLF working trees that diverge byte-by-byte from the LF stored in the
# repo, breaking `forge fmt --check`, gas snapshots, and any tool that
# compares file content against committed bytes.

* text=auto eol=lf

# Solidity, Foundry, and config files are unambiguously text — pin LF.
*.sol      text eol=lf
*.toml     text eol=lf
*.lock     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.sh       text eol=lf

# Snapshot/diff artifacts must stay LF for stable hashing.
.gas-snapshot text eol=lf

# Binary files: never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
